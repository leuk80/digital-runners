---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const siteUrl = 'https://digital-runners.ch';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    ...(item.href ? { "item": `${siteUrl}${item.href}` } : {})
  }))
};
---

<nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-slate-500">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && <span class="text-slate-300">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-cyan-600 transition-colors">{item.label}</a>
        ) : (
          <span class="text-slate-700 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
