---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
}

const { title, items } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<section class="py-16 bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    {title && (
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 text-center mb-10">{title}</h2>
    )}
    <div class="space-y-4">
      {items.map(item => (
        <details class="group bg-white rounded-xl border border-slate-100 shadow-sm">
          <summary class="flex items-center justify-between cursor-pointer px-6 py-5 font-semibold text-slate-900 hover:text-cyan-600 transition-colors">
            {item.question}
            <span class="ml-4 text-slate-400 group-open:rotate-180 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </span>
          </summary>
          <div class="px-6 pb-5 text-slate-600 leading-relaxed">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
