---
import '../styles/global.css';
import '@fontsource-variable/inter';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogImage?: string;
  alternatePath?: string;
}

const { title, description, lang, ogImage, alternatePath } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://www.digital-runners.ch');
const otherLang = lang === 'de' ? 'en' : 'de';
const otherPath = alternatePath ?? Astro.url.pathname.replace(`/${lang}`, `/${otherLang}`);
const ogLocale = lang === 'de' ? 'de_CH' : 'en_US';
const ogLocaleAlt = lang === 'de' ? 'en_US' : 'de_CH';
---

<!doctype html>
<html lang={lang} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Digital Runners" />
    <meta name="geo.region" content="CH" />
    <meta name="geo.placename" content="Schweiz" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      hreflang={otherLang}
      href={new URL(otherPath, canonicalUrl.origin)}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL('/de/', canonicalUrl.origin)}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Digital Runners" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Digital Runners Blog" href={`/${lang}/rss.xml`} />
    <title>{title} | Digital Runners</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Digital Runners",
      "url": "https://www.digital-runners.ch",
      "logo": "https://www.digital-runners.ch/favicon.svg",
      "description": lang === 'de'
        ? "Ihr Schweizer UniFi Partner für professionelle Netzwerklösungen"
        : "Your Swiss UniFi Partner for professional network solutions",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@digital-runners.ch",
        "contactType": "customer service",
        "availableLanguage": ["German", "English"]
      },
      "areaServed": {
        "@type": "Country",
        "name": "Switzerland"
      }
    })} />
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-full bg-white text-slate-800">
    <Header lang={lang} alternatePath={alternatePath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
