---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft);
  return allPosts.map(post => ({
    params: { slug: post.slug.replace(/^de\//, '') },
    props: { post, allPosts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);
const lang = 'de' as const;
const t = useTranslations(lang);
const wordCount = post.body.split(/\s+/).length;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://digital-runners.ch');
const postSlug = post.slug.replace(/^de\//, '');
const ogImageUrl = post.data.image ?? `https://digital-runners.ch/og/de/${postSlug}.png`;

const currentTags = post.data.tags ?? [];
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.tags?.some(t => currentTags.includes(t)))
  .sort((a, b) => {
    const aOverlap = a.data.tags?.filter(t => currentTags.includes(t)).length ?? 0;
    const bOverlap = b.data.tags?.filter(t => currentTags.includes(t)).length ?? 0;
    return bOverlap - aOverlap || b.data.pubDate.getTime() - a.data.pubDate.getTime();
  })
  .slice(0, 3);

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": post.data.author ?? "Digital Runners",
    "url": "https://digital-runners.ch"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Digital Runners",
    "url": "https://digital-runners.ch",
    "logo": { "@type": "ImageObject", "url": "https://digital-runners.ch/favicon.svg" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl.href },
  "inLanguage": "de-CH",
  "wordCount": wordCount,
  ...(post.data.updatedDate ? { "dateModified": post.data.updatedDate.toISOString() } : {}),
  "image": ogImageUrl,
  ...(post.data.tags ? { "keywords": post.data.tags.join(", ") } : {})
};
---

<BaseLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImageUrl}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <Breadcrumbs items={[
    { label: 'Home', href: '/de/' },
    { label: 'Blog', href: '/de/blog' },
    { label: post.data.title }
  ]} />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <header class="mb-10">
      <div class="flex items-center gap-3">
        <time class="text-xs text-slate-400 uppercase tracking-wider">
          {post.data.pubDate.toLocaleDateString('de-CH', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-slate-300">·</span>
        <span class="text-xs text-slate-400">{Math.ceil(post.body.split(/\s+/).length / 200)} min Lesezeit</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mt-3 mb-4">{post.data.title}</h1>
      <p class="text-lg text-slate-600">{post.data.description}</p>
      {post.data.tags && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <a href={`/de/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded-full hover:bg-cyan-100 hover:text-cyan-700 transition-colors">{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-slate prose-lg max-w-none prose-headings:font-bold prose-a:text-cyan-600">
      <Content />
    </div>

    {relatedPosts.length > 0 && (
      <aside class="mt-16 pt-10 border-t border-slate-200">
        <h2 class="text-xl font-bold text-slate-900 mb-6">Verwandte Artikel</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {relatedPosts.map(rp => (
            <a href={`/de/blog/${rp.slug.replace(/^de\//, '')}`} class="group block bg-slate-50 rounded-xl p-5 hover:bg-white hover:shadow-sm transition-all border border-slate-100">
              <time class="text-xs text-slate-400">{rp.data.pubDate.toLocaleDateString('de-CH', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              <h3 class="font-semibold text-slate-900 mt-1 text-sm group-hover:text-cyan-600 transition-colors">{rp.data.title}</h3>
            </a>
          ))}
        </div>
      </aside>
    )}
  </article>
</BaseLayout>
