---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import { industries } from '../../../data/industries';
import type { Industry } from '../../../data/industries';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
  return industries.map((industry) => ({
    params: { slug: industry.enSlug },
    props: { industry, allPosts },
  }));
}

const { industry, allPosts } = Astro.props;
const c = industry.en;

const relatedPosts = (industry.relatedTags ?? []).length > 0
  ? allPosts
      .filter(post => post.data.tags?.some(tag => industry.relatedTags!.includes(tag)))
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
      .slice(0, 3)
  : [];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": c.title,
  "description": c.metaDescription,
  "provider": {
    "@type": "Organization",
    "name": "Digital Runners",
    "url": "https://www.digital-runners.ch"
  },
  "areaServed": { "@type": "Country", "name": "Switzerland" },
  "serviceType": c.name,
  "url": `https://www.digital-runners.ch/en/industries/${industry.enSlug}`
};
---

<BaseLayout lang="en" title={c.title} description={c.metaDescription} alternatePath={`/de/branchen/${industry.slug}`}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <Breadcrumbs items={[
    { label: 'Home', href: '/en/' },
    { label: 'Industries', href: '/en/referenzen' },
    { label: c.name }
  ]} />
  <!-- Hero -->
  <div class="bg-gradient-to-br from-slate-900 to-blue-950 text-white py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      </a>
      <div class="flex items-center gap-3 mb-4">
        <Icon name={industry.icon} class="h-10 w-10 text-cyan-400" />
        <span class="text-cyan-400 font-semibold text-sm uppercase tracking-widest">Industry</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{c.title}</h1>
      <p class="text-slate-300 text-lg max-w-2xl">{c.subtitle}</p>
    </div>
  </div>

  <!-- Challenges -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Typical Challenges</h2>
        <p class="text-slate-500">What businesses in this industry deal with.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {c.challenges.map((ch) => (
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
            <div class="mb-4"><Icon name={ch.icon} class="h-8 w-8 text-cyan-500" /></div>
            <h3 class="font-bold text-slate-900 mb-2">{ch.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{ch.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Solution -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-8 text-center">Our UniFi Solution</h2>
        <ul class="space-y-4">
          {c.solutions.map((sol) => (
            <li class="flex items-start gap-4 bg-white rounded-xl px-6 py-4 shadow-sm border border-slate-100">
              <Icon name="CheckBig" class="h-5 w-5 text-cyan-500 shrink-0 mt-0.5" />
              <span class="text-slate-700">{sol}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Recommended Products -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 text-center mb-12">Recommended Solutions</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {c.products.map((p) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 text-center hover:shadow-md transition-shadow">
            <div class="flex justify-center mb-4"><Icon name={p.icon} class="h-8 w-8 text-cyan-500" /></div>
            <h3 class="font-bold text-slate-900 mb-3">{p.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {relatedPosts.length > 0 && (
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 text-center mb-10">Related Blog Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(post => (
            <a href={`/en/blog/${post.slug.replace(/^en\//, '')}`} class="group block bg-white rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <div class="p-6">
                <time class="text-xs text-slate-400">{post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                <h3 class="font-bold text-slate-900 mt-2 mb-2 group-hover:text-cyan-600 transition-colors">{post.data.title}</h3>
                <p class="text-sm text-slate-600 line-clamp-2">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {c.faqs && c.faqs.length > 0 && (
    <FAQ title="Frequently Asked Questions" items={c.faqs} />
  )}

  <!-- CTA -->
  <section class="bg-cyan-500 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">
        Ready for your UniFi solution?
      </h2>
      <p class="text-slate-800 mb-8 max-w-xl mx-auto">
        Contact us for a no-obligation consultation. We will find the optimal solution for your industry.
      </p>
      <a
        href="/en/kontakt"
        class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors"
      >
        Get in touch now
      </a>
    </div>
  </section>
</BaseLayout>
