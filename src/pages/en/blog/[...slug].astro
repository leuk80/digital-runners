---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug.replace(/^en\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = 'en' as const;
const t = useTranslations(lang);
const wordCount = post.body.split(/\s+/).length;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://www.digital-runners.ch');

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": post.data.author ?? "Digital Runners",
    "url": "https://www.digital-runners.ch"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Digital Runners",
    "url": "https://www.digital-runners.ch",
    "logo": { "@type": "ImageObject", "url": "https://www.digital-runners.ch/favicon.svg" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl.href },
  "inLanguage": "en",
  "wordCount": wordCount,
  ...(post.data.updatedDate ? { "dateModified": post.data.updatedDate.toISOString() } : {}),
  ...(post.data.image ? { "image": post.data.image } : {}),
  ...(post.data.tags ? { "keywords": post.data.tags.join(", ") } : {})
};
---

<BaseLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <Breadcrumbs items={[
    { label: 'Home', href: '/en/' },
    { label: 'Blog', href: '/en/blog' },
    { label: post.data.title }
  ]} />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <header class="mb-10">
      <div class="flex items-center gap-3">
        <time class="text-xs text-slate-400 uppercase tracking-wider">
          {post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-slate-300">·</span>
        <span class="text-xs text-slate-400">{Math.ceil(post.body.split(/\s+/).length / 200)} min read</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mt-3 mb-4">{post.data.title}</h1>
      <p class="text-lg text-slate-600">{post.data.description}</p>
      {post.data.tags && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-slate prose-lg max-w-none prose-headings:font-bold prose-a:text-cyan-600">
      <Content />
    </div>
  </article>
</BaseLayout>
